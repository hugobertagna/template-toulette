# Copiez ces variables dans Vercel → Project → Settings → Environment Variables
# https://resend.com/api-keys

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Domaine / adresse d’envoi vérifiés sur Resend (recommandé en production)
# RESEND_FROM=Roulette Restaurant <coupons@votredomaine.com>

# Copie de chaque envoi coupon (BCC) — tes adresses, séparées par des virgules
# OWNER_EMAIL=hugo@example.com

# CSV des inscriptions sur Vercel Blob (optionnel) — crée un store Blob sur Vercel puis colle le token lecture/écriture
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
# Nom du fichier dans le store (défaut roulette-leads.csv)
# LEADS_CSV_FILENAME=roulette-leads.csv

